<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Ruman Asif | Software Engineer</title>
  <style>
    /* ── Reset & base ──────────────────────────────────────────────── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:        #0d1117;
      --surface:   #161b22;
      --border:    #30363d;
      --accent:    #58a6ff;
      --accent2:   #3fb950;
      --text:      #e6edf3;
      --muted:     #8b949e;
      --radius:    10px;
      --max-w:     1100px;
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Oxygen, sans-serif;
      background: var(--bg);
      color: var(--text);
      line-height: 1.7;
      font-size: 16px;
    }

    a { color: var(--accent); text-decoration: none; }
    a:hover { text-decoration: underline; }

    /* ── Nav ───────────────────────────────────────────────────────── */
    nav {
      position: sticky; top: 0; z-index: 100;
      background: rgba(13, 17, 23, 0.85);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border);
    }
    .nav-inner {
      max-width: var(--max-w);
      margin: 0 auto;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0.85rem 1.5rem;
    }
    .nav-brand { font-weight: 700; font-size: 1.1rem; color: var(--text); letter-spacing: .02em; }
    .nav-brand span { color: var(--accent); }
    .nav-links { display: flex; gap: 1.6rem; list-style: none; }
    .nav-links a { color: var(--muted); font-size: 0.9rem; transition: color .2s; }
    .nav-links a:hover { color: var(--text); text-decoration: none; }

    /* ── Sections ──────────────────────────────────────────────────── */
    section { padding: 5rem 1.5rem; }
    .container { max-width: var(--max-w); margin: 0 auto; }

    .section-label {
      display: inline-block;
      font-size: 0.78rem;
      font-weight: 600;
      letter-spacing: .12em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 0.6rem;
    }
    h2.section-title {
      font-size: clamp(1.6rem, 4vw, 2.2rem);
      font-weight: 700;
      margin-bottom: 0.5rem;
    }
    .section-sub {
      color: var(--muted);
      max-width: 560px;
      margin-bottom: 3rem;
    }
    hr.divider {
      border: none;
      border-top: 1px solid var(--border);
      margin: 0;
    }

    /* ── Hero ──────────────────────────────────────────────────────── */
    #hero {
      min-height: 92vh;
      display: flex;
      align-items: center;
      background: radial-gradient(ellipse at 60% 0%, rgba(88,166,255,.08) 0%, transparent 60%);
    }
    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      background: rgba(88,166,255,.1);
      border: 1px solid rgba(88,166,255,.3);
      border-radius: 999px;
      padding: 0.3rem 0.9rem;
      font-size: 0.82rem;
      color: var(--accent);
      margin-bottom: 1.5rem;
    }
    .hero-badge::before { content: "●"; font-size: 0.55rem; color: var(--accent2); }
    h1 {
      font-size: clamp(2.4rem, 7vw, 4.2rem);
      font-weight: 800;
      line-height: 1.1;
      letter-spacing: -.02em;
      margin-bottom: 1rem;
    }
    h1 .highlight { color: var(--accent); }
    .hero-desc {
      font-size: 1.15rem;
      color: var(--muted);
      max-width: 560px;
      margin-bottom: 2rem;
    }
    .hero-cta { display: flex; gap: 1rem; flex-wrap: wrap; }
    .btn {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      padding: 0.7rem 1.4rem;
      border-radius: var(--radius);
      font-size: 0.92rem;
      font-weight: 600;
      cursor: pointer;
      transition: opacity .2s, transform .15s;
    }
    .btn:hover { opacity: 0.85; transform: translateY(-1px); text-decoration: none; }
    .btn-primary  { background: var(--accent);  color: #000; }
    .btn-outline  { background: transparent; color: var(--text); border: 1px solid var(--border); }

    /* ── About ─────────────────────────────────────────────────────── */
    #about { background: var(--surface); }
    .about-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
      align-items: center;
    }
    .about-text p { color: var(--muted); margin-bottom: 1rem; }
    .stats-row {
      display: flex;
      gap: 2rem;
      margin-top: 1.8rem;
    }
    .stat { border-left: 3px solid var(--accent); padding-left: 0.9rem; }
    .stat-num { font-size: 2rem; font-weight: 700; color: var(--text); }
    .stat-label { font-size: 0.82rem; color: var(--muted); }
    .about-skills h3 { font-size: 1rem; margin-bottom: 1rem; color: var(--muted); font-weight: 500; }
    .skill-pills { display: flex; flex-wrap: wrap; gap: 0.5rem; }
    .pill {
      background: rgba(88,166,255,.1);
      border: 1px solid rgba(88,166,255,.2);
      border-radius: 999px;
      padding: 0.25rem 0.8rem;
      font-size: 0.8rem;
      color: var(--accent);
    }

    /* ── Projects ──────────────────────────────────────────────────── */
    #projects { background: var(--bg); }
    .projects-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(310px, 1fr));
      gap: 1.5rem;
    }
    .card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 1.6rem;
      display: flex;
      flex-direction: column;
      gap: 0.8rem;
      transition: border-color .2s, transform .2s;
    }
    .card:hover { border-color: var(--accent); transform: translateY(-3px); }
    .card-header { display: flex; align-items: flex-start; justify-content: space-between; gap: 0.5rem; }
    .card-icon {
      width: 38px; height: 38px;
      border-radius: 8px;
      background: rgba(88,166,255,.12);
      display: flex; align-items: center; justify-content: center;
      font-size: 1.1rem;
      flex-shrink: 0;
    }
    .card h3 { font-size: 1.05rem; font-weight: 700; flex: 1; }
    .card-desc { color: var(--muted); font-size: 0.9rem; flex: 1; }
    .card-stack {
      font-size: 0.78rem;
      color: var(--accent2);
      font-family: "SFMono-Regular", Consolas, monospace;
      border-top: 1px solid var(--border);
      padding-top: 0.8rem;
      margin-top: auto;
    }
    .card-link {
      font-size: 0.85rem;
      font-weight: 600;
      display: inline-flex;
      align-items: center;
      gap: 0.3rem;
    }
    .card-link::after { content: "→"; transition: transform .2s; }
    .card-link:hover::after { transform: translateX(3px); }

    /* ── DB Badge ──────────────────────────────────────────────────── */
    .db-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      background: rgba(63,185,80,.08);
      border: 1px solid rgba(63,185,80,.25);
      border-radius: 999px;
      padding: 0.3rem 0.9rem;
      font-size: 0.8rem;
      color: var(--accent2);
      margin-bottom: 2rem;
    }
    .db-badge::before { content: "⬤"; font-size: 0.5rem; }

    /* ── Footer ────────────────────────────────────────────────────── */
    footer {
      background: var(--surface);
      border-top: 1px solid var(--border);
      text-align: center;
      padding: 2rem 1.5rem;
      color: var(--muted);
      font-size: 0.85rem;
    }
    footer .footer-links { display: flex; justify-content: center; gap: 1.5rem; margin-top: 0.6rem; }

    /* ── Responsive ────────────────────────────────────────────────── */
    @media (max-width: 700px) {
      .about-grid { grid-template-columns: 1fr; gap: 2rem; }
      .stats-row  { gap: 1.2rem; }
      .nav-links  { display: none; }
    }
  </style>
</head>
<body>

<!-- ── Navigation ──────────────────────────────────────────────────── -->
<nav>
  <div class="nav-inner">
    <span class="nav-brand">Ruman<span>.</span></span>
    <ul class="nav-links">
      <li><a href="#about">About</a></li>
      <li><a href="#projects">Projects</a></li>
      <li><a href="#contact">Contact</a></li>
    </ul>
  </div>
</nav>

<!-- ── Hero ────────────────────────────────────────────────────────── -->
<section id="hero">
  <div class="container">
    <div class="hero-badge">Available for opportunities</div>
    <h1>
      Hi, I'm <span class="highlight">Ruman Asif</span>.<br/>
      I build things for the cloud.
    </h1>
    <p class="hero-desc">
      Software Engineer specialising in cloud-native applications, distributed systems,
      and full-stack development. I turn complex requirements into clean, scalable solutions.
    </p>
    <div class="hero-cta">
      <a class="btn btn-primary" href="#projects">View Projects</a>
      <a class="btn btn-outline" href="#contact">Get in Touch</a>
    </div>
  </div>
</section>

<hr class="divider" />

<!-- ── About ───────────────────────────────────────────────────────── -->
<section id="about">
  <div class="container">
    <div class="about-grid">
      <div class="about-text">
        <span class="section-label">About Me</span>
        <h2 class="section-title">Passionate about cloud &amp; software engineering</h2>
        <p>
          I'm a Computer Science student with a deep interest in cloud computing,
          DevOps, and backend engineering. I enjoy architecting systems that are
          resilient, cost-efficient, and easy to operate.
        </p>
        <p>
          Currently exploring AWS services, distributed databases, and microservice
          architectures as part of my university curriculum and side projects.
        </p>
        <div class="stats-row">
          <div class="stat">
            <div class="stat-num">4+</div>
            <div class="stat-label">Projects</div>
          </div>
          <div class="stat">
            <div class="stat-num">3+</div>
            <div class="stat-label">Years coding</div>
          </div>
          <div class="stat">
            <div class="stat-num">AWS</div>
            <div class="stat-label">Certified (in progress)</div>
          </div>
        </div>
      </div>
      <div class="about-skills">
        <h3>Core technologies</h3>
        <div class="skill-pills">
          <span class="pill">Node.js</span>
          <span class="pill">Python</span>
          <span class="pill">AWS EC2</span>
          <span class="pill">AWS S3</span>
          <span class="pill">MySQL</span>
          <span class="pill">PostgreSQL</span>
          <span class="pill">Docker</span>
          <span class="pill">Express</span>
          <span class="pill">React</span>
          <span class="pill">Linux</span>
          <span class="pill">Git</span>
          <span class="pill">REST APIs</span>
        </div>
      </div>
    </div>
  </div>
</section>

<hr class="divider" />

<!-- ── Projects ─────────────────────────────────────────────────────── -->
<section id="projects">
  <div class="container">
    <span class="section-label">Portfolio</span>
    <h2 class="section-title">Featured Projects</h2>
    <p class="section-sub">
      A selection of software engineering projects. Each card is rendered dynamically
      from a MySQL database running on this same EC2 instance.
    </p>

    <div class="db-badge">
      Live data — <%= projects.length %> project<%= projects.length !== 1 ? 's' : '' %> loaded from MySQL
    </div>

    <div class="projects-grid">
      <% projects.forEach(function(project, i) { %>
      <%
        const icons = ['☁️', '📡', '💬', '🧠', '🔐', '⚡'];
        const icon  = icons[i % icons.length];
      %>
      <div class="card">
        <div class="card-header">
          <div class="card-icon"><%= icon %></div>
          <h3><%= project.title %></h3>
        </div>
        <p class="card-desc"><%= project.description %></p>
        <div class="card-stack"><%= project.tech_stack %></div>
        <% if (project.live_url) { %>
          <a class="card-link" href="<%= project.live_url %>" target="_blank" rel="noopener">
            View Project
          </a>
        <% } %>
      </div>
      <% }); %>
    </div>

    <% if (projects.length === 0) { %>
    <p style="color: var(--muted); text-align:center; margin-top:2rem;">
      No projects found — run <code>node db/init.js</code> to seed the database.
    </p>
    <% } %>
  </div>
</section>

<hr class="divider" />

<!-- ── Contact ──────────────────────────────────────────────────────── -->
<section id="contact" style="background: var(--surface);">
  <div class="container" style="text-align:center; max-width:600px;">
    <span class="section-label">Contact</span>
    <h2 class="section-title">Let's work together</h2>
    <p style="color:var(--muted); margin-bottom:2rem;">
      I'm open to internship opportunities, freelance projects, and collaborative
      research. Feel free to reach out via email or GitHub.
    </p>
    <div style="display:flex; justify-content:center; gap:1rem; flex-wrap:wrap;">
      <a class="btn btn-primary"  href="mailto:rumanasif3@gmail.com">Email Me</a>
      <a class="btn btn-outline"  href="https://github.com" target="_blank" rel="noopener">GitHub</a>
      <a class="btn btn-outline"  href="https://linkedin.com" target="_blank" rel="noopener">LinkedIn</a>
    </div>
  </div>
</section>

<!-- ── Footer ───────────────────────────────────────────────────────── -->
<footer>
  <div>Built with Node.js · Express · EJS · MySQL · Deployed on AWS EC2</div>
  <div class="footer-links">
    <a href="#hero">Back to top ↑</a>
  </div>
</footer>

</body>
</html>
