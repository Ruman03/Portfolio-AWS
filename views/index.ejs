<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Hassan Tahir is a cloud and backend engineer building reliable, thoughtful digital systems." />
  <meta name="theme-color" content="#172039" />
  <title>Hassan Tahir | Cloud &amp; Backend Engineer</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; }
    * { margin: 0; }
    :root { --ink:#172039; --ink-soft:#4d566c; --paper:#f7f3ea; --paper-deep:#eee8da; --white:#fffdf8; --coral:#ff6a4d; --coral-dark:#d9462a; --lime:#c8ef67; --blue:#85b9ff; --line:rgba(23,32,57,.16); --shadow:0 18px 60px rgba(23,32,57,.11); --radius:24px; --max:1180px; }
    html { scroll-behavior:smooth; scroll-padding-top:90px; }
    body { min-width:320px; background:var(--paper); color:var(--ink); font-family:"Manrope",sans-serif; font-size:16px; line-height:1.7; overflow-x:hidden; }
    body::before { content:""; position:fixed; inset:0; pointer-events:none; opacity:.22; z-index:20; background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 180 180' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.85' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='.07'/%3E%3C/svg%3E"); }
    a { color:inherit; text-decoration:none; } button { font:inherit; } :focus-visible { outline:3px solid var(--blue); outline-offset:4px; }
    .container { width:min(calc(100% - 40px),var(--max)); margin-inline:auto; } .mono { font-family:"DM Mono",monospace; }
    .site-nav { position:fixed; top:18px; left:50%; transform:translateX(-50%); width:min(calc(100% - 32px),1180px); z-index:50; border:1px solid rgba(255,255,255,.14); border-radius:18px; background:rgba(23,32,57,.92); color:var(--white); box-shadow:0 10px 34px rgba(23,32,57,.18); backdrop-filter:blur(16px); }
    .nav-inner { height:66px; display:flex; align-items:center; justify-content:space-between; padding:0 12px 0 22px; }
    .brand { display:inline-flex; align-items:center; gap:10px; font-weight:800; letter-spacing:-.03em; }
    .brand-mark { width:28px; height:28px; display:grid; place-items:center; border-radius:8px; background:var(--coral); color:var(--ink); font:500 12px "DM Mono",monospace; }
    .nav-links { display:flex; align-items:center; gap:6px; list-style:none; padding:0; }
    .nav-links a { display:block; border-radius:10px; padding:9px 13px; color:#c9cede; font-size:.86rem; font-weight:600; transition:.2s ease; }
    .nav-links a:hover { background:rgba(255,255,255,.08); color:white; }
    .nav-links .nav-cta { background:var(--lime); color:var(--ink); margin-left:6px; } .nav-links .nav-cta:hover { background:#d8ff79; color:var(--ink); }
    .menu-button { display:none; width:42px; height:42px; border:0; border-radius:11px; background:rgba(255,255,255,.08); color:white; cursor:pointer; }
    .hero { min-height:800px; padding:170px 0 95px; position:relative; display:grid; align-items:center; }
    .hero::after { content:""; position:absolute; width:540px; height:540px; right:-260px; top:160px; border:1px solid var(--line); border-radius:50%; box-shadow:0 0 0 70px rgba(255,106,77,.04),0 0 0 140px rgba(133,185,255,.04); }
    .hero-grid { display:grid; grid-template-columns:1.35fr .65fr; gap:90px; align-items:center; position:relative; z-index:1; }
    .eyebrow { display:inline-flex; align-items:center; gap:10px; margin-bottom:24px; font:500 .76rem "DM Mono",monospace; letter-spacing:.08em; text-transform:uppercase; }
    .eyebrow::before { content:""; width:30px; height:2px; background:var(--coral); }
    h1 { max-width:850px; font-size:clamp(3.4rem,7.5vw,7rem); font-weight:800; line-height:.94; letter-spacing:-.075em; } h1 .accent { color:var(--coral); }
    .hero-copy { max-width:650px; margin:28px 0 34px; color:var(--ink-soft); font-size:clamp(1.02rem,1.5vw,1.2rem); }
    .button-row { display:flex; flex-wrap:wrap; gap:12px; }
    .button { min-height:52px; display:inline-flex; align-items:center; justify-content:center; gap:10px; padding:0 22px; border-radius:14px; font-weight:700; font-size:.9rem; transition:transform .2s ease,box-shadow .2s ease,background .2s ease; }
    .button:hover { transform:translateY(-3px); } .button-primary { background:var(--ink); color:white; box-shadow:0 10px 24px rgba(23,32,57,.18); } .button-secondary { border:1px solid var(--line); background:rgba(255,255,255,.42); }
    .arrow { font-size:1.15em; transition:transform .2s ease; } .button:hover .arrow,.project-link:hover .arrow { transform:translateX(4px); }
    .orbit-card { position:relative; aspect-ratio:1/1.1; max-width:330px; justify-self:end; }
    .portrait-shape { position:absolute; inset:4% 4% 11%; display:grid; place-items:center; overflow:hidden; border:2px solid var(--ink); border-radius:48% 48% 18px 18px; background:var(--blue); box-shadow:14px 14px 0 var(--ink); }
    .portrait-initials { color:var(--ink); font-size:7rem; font-weight:800; line-height:1; letter-spacing:-.12em; transform:translateX(-.08em); }
    .portrait-grid { position:absolute; inset:0; opacity:.22; background-image:linear-gradient(var(--ink) 1px,transparent 1px),linear-gradient(90deg,var(--ink) 1px,transparent 1px); background-size:28px 28px; }
    .status-chip { position:absolute; bottom:0; left:-42px; z-index:2; display:flex; align-items:center; gap:9px; padding:11px 15px; border:2px solid var(--ink); border-radius:12px; background:var(--lime); font:500 .72rem "DM Mono",monospace; box-shadow:6px 6px 0 var(--ink); }
    .status-dot { width:8px; height:8px; border-radius:50%; background:#398e35; box-shadow:0 0 0 4px rgba(57,142,53,.16); }
    .cloud-chip { position:absolute; top:12%; right:-38px; z-index:2; padding:10px 14px; border:2px solid var(--ink); border-radius:12px; background:var(--coral); font:500 .72rem "DM Mono",monospace; transform:rotate(5deg); }
    .marquee { overflow:hidden; border-block:1px solid var(--line); background:var(--ink); color:white; }
    .marquee-track { width:max-content; display:flex; align-items:center; gap:28px; padding:16px 0; animation:ticker 25s linear infinite; font:500 .72rem "DM Mono",monospace; letter-spacing:.1em; text-transform:uppercase; }
    .marquee-track span::after { content:"✦"; margin-left:28px; color:var(--coral); } @keyframes ticker { to { transform:translateX(-50%); } }
    section { padding:112px 0; }
    .section-head { display:grid; grid-template-columns:.45fr 1fr; gap:50px; align-items:start; margin-bottom:60px; }
    .section-index { color:var(--coral-dark); font:500 .76rem "DM Mono",monospace; letter-spacing:.08em; text-transform:uppercase; }
    .section-title { max-width:750px; font-size:clamp(2.4rem,5vw,4.4rem); font-weight:800; line-height:1.03; letter-spacing:-.055em; }
    .section-intro { max-width:650px; margin-top:18px; color:var(--ink-soft); font-size:1.05rem; }
    .about { background:var(--white); } .about-grid { display:grid; grid-template-columns:.85fr 1.15fr; gap:90px; align-items:start; }
    .principle-card { position:sticky; top:115px; padding:30px; border:2px solid var(--ink); border-radius:var(--radius); background:var(--lime); box-shadow:10px 10px 0 var(--ink); }
    .principle-card .mono { display:block; margin-bottom:44px; font-size:.72rem; text-transform:uppercase; letter-spacing:.08em; }
    .principle-card blockquote { font-size:clamp(1.45rem,2.5vw,2.1rem); font-weight:700; line-height:1.25; letter-spacing:-.035em; }
    .about-copy>p { color:var(--ink-soft); font-size:1.08rem; margin-bottom:20px; }
    .stats { display:grid; grid-template-columns:repeat(3,1fr); margin-top:44px; border-block:1px solid var(--line); }
    .stat { padding:22px 12px 22px 0; } .stat+.stat { border-left:1px solid var(--line); padding-left:22px; } .stat strong { display:block; font-size:1.8rem; line-height:1.2; letter-spacing:-.04em; } .stat span { color:var(--ink-soft); font-size:.78rem; }
    .experience { background:var(--paper-deep); } .timeline { border-top:1px solid var(--line); }
    .role { display:grid; grid-template-columns:.45fr .78fr 1.4fr; gap:35px; padding:38px 0; border-bottom:1px solid var(--line); transition:padding .2s ease; } .role:hover { padding-left:12px; }
    .role-date { color:var(--coral-dark); font:500 .72rem "DM Mono",monospace; letter-spacing:.04em; text-transform:uppercase; } .role h3 { font-size:1.3rem; letter-spacing:-.025em; } .role-company { color:var(--ink-soft); font-size:.85rem; } .role p { color:var(--ink-soft); font-size:.95rem; }
    .projects { background:var(--ink); color:white; } .projects .section-index { color:var(--coral); } .projects .section-intro { color:#aeb6ca; }
    .db-status { display:inline-flex; align-items:center; gap:10px; margin-bottom:34px; padding:9px 13px; border:1px solid rgba(200,239,103,.3); border-radius:999px; background:rgba(200,239,103,.08); color:var(--lime); font:400 .7rem "DM Mono",monospace; }
    .db-status .status-dot { background:var(--lime); box-shadow:0 0 0 4px rgba(200,239,103,.13); }
    .projects-grid { display:grid; grid-template-columns:repeat(2,1fr); gap:18px; }
    .project-card { min-height:360px; display:flex; flex-direction:column; padding:30px; border:1px solid rgba(255,255,255,.13); border-radius:var(--radius); background:#202a47; transition:transform .25s ease,border-color .25s ease; overflow:hidden; position:relative; }
    .project-card::after { content:attr(data-number); position:absolute; right:-4px; top:-38px; color:rgba(255,255,255,.035); font-size:11rem; font-weight:800; line-height:1; letter-spacing:-.08em; } .project-card:nth-child(2n) { background:#2b2647; } .project-card:hover { transform:translateY(-5px); border-color:var(--coral); }
    .project-meta { display:flex; align-items:center; justify-content:space-between; position:relative; z-index:1; } .project-number { color:var(--coral); font:500 .72rem "DM Mono",monospace; }
    .project-icon { width:44px; height:44px; display:grid; place-items:center; border-radius:50%; background:var(--coral); color:var(--ink); } .project-icon svg { width:21px; height:21px; }
    .project-card h3 { max-width:410px; margin-top:45px; font-size:clamp(1.4rem,2.3vw,2rem); line-height:1.15; letter-spacing:-.035em; position:relative; z-index:1; }
    .project-description { max-width:520px; margin-top:15px; color:#b7bed0; font-size:.92rem; position:relative; z-index:1; }
    .project-footer { display:flex; align-items:end; justify-content:space-between; gap:20px; margin-top:auto; padding-top:28px; position:relative; z-index:1; }
    .project-stack { max-width:70%; color:var(--lime); font:400 .68rem/1.65 "DM Mono",monospace; text-transform:uppercase; } .project-link { display:inline-flex; align-items:center; gap:7px; font-size:.78rem; font-weight:700; white-space:nowrap; }
    .empty-state { grid-column:1/-1; padding:50px; border:1px dashed rgba(255,255,255,.2); border-radius:var(--radius); text-align:center; color:#b7bed0; }
    .skills { background:var(--paper); } .skills-layout { display:grid; grid-template-columns:.7fr 1.3fr; gap:70px; } .skills-note { color:var(--ink-soft); }
    .skill-list { display:flex; flex-wrap:wrap; gap:10px; align-content:start; } .skill { padding:11px 16px; border:1px solid var(--line); border-radius:999px; background:rgba(255,255,255,.45); font:500 .76rem "DM Mono",monospace; transition:.2s ease; } .skill:hover { background:var(--blue); border-color:var(--ink); transform:rotate(-1deg); }
    .contact { position:relative; overflow:hidden; background:var(--coral); padding:120px 0; } .contact::before { content:"HT"; position:absolute; right:-20px; bottom:-100px; color:rgba(23,32,57,.07); font-size:min(32vw,410px); font-weight:800; line-height:1; letter-spacing:-.12em; }
    .contact-inner { position:relative; z-index:1; max-width:920px; } .contact .eyebrow::before { background:var(--ink); } .contact h2 { max-width:850px; font-size:clamp(3rem,7vw,6.5rem); font-weight:800; line-height:.95; letter-spacing:-.07em; } .contact p { max-width:610px; margin:25px 0 34px; color:#512a2a; font-size:1.05rem; } .contact .button-secondary { border-color:rgba(23,32,57,.3); background:rgba(255,255,255,.2); }
    footer { background:var(--ink); color:#9fa8bd; } .footer-inner { min-height:110px; display:flex; align-items:center; justify-content:space-between; gap:30px; font-size:.78rem; } .footer-links { display:flex; gap:22px; } .footer-links a:hover { color:white; }
    .reveal { opacity:0; transform:translateY(24px); transition:opacity .7s ease,transform .7s ease; } .reveal.visible { opacity:1; transform:none; }
    @media (prefers-reduced-motion:reduce) { html { scroll-behavior:auto; } *,*::before,*::after { animation-duration:.01ms!important; animation-iteration-count:1!important; transition-duration:.01ms!important; } .reveal { opacity:1; transform:none; } }
    @media (max-width:900px) { .hero { min-height:auto; } .hero-grid { grid-template-columns:1fr; gap:70px; } .orbit-card { width:280px; justify-self:start; } .section-head,.about-grid,.skills-layout { grid-template-columns:1fr; gap:28px; } .principle-card { position:relative; top:auto; max-width:620px; } .role { grid-template-columns:.5fr 1fr; } .role p { grid-column:2; } }
    @media (max-width:700px) { .container { width:min(calc(100% - 30px),var(--max)); } .site-nav { top:10px; width:calc(100% - 20px); } .menu-button { display:grid; place-items:center; } .nav-links { display:none; position:absolute; top:73px; left:0; right:0; padding:10px; border-radius:16px; background:var(--ink); box-shadow:var(--shadow); } .nav-links.open { display:grid; } .nav-links a { padding:12px 14px; } .nav-links .nav-cta { margin-left:0; margin-top:4px; text-align:center; } .hero { padding-top:135px; } .hero::after { display:none; } h1 { font-size:clamp(3.2rem,17vw,5.1rem); } section { padding:82px 0; } .stats { grid-template-columns:1fr; } .stat+.stat { border-left:0; border-top:1px solid var(--line); padding-left:0; } .role { grid-template-columns:1fr; gap:8px; } .role p { grid-column:auto; margin-top:8px; } .projects-grid { grid-template-columns:1fr; } .project-card { min-height:400px; padding:24px; } .project-footer { align-items:start; flex-direction:column; } .project-stack { max-width:100%; } .footer-inner { padding:30px 0; align-items:flex-start; flex-direction:column; } }
  </style>
</head>
<body>
  <nav class="site-nav" aria-label="Primary navigation"><div class="nav-inner"><a class="brand" href="#top" aria-label="Hassan Tahir, home"><span class="brand-mark">HT</span>Hassan Tahir</a><button class="menu-button" type="button" aria-expanded="false" aria-controls="nav-links" aria-label="Open navigation menu"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M4 7h16M4 12h16M4 17h16"/></svg></button><ul class="nav-links" id="nav-links"><li><a href="#about">About</a></li><li><a href="#experience">Experience</a></li><li><a href="#projects">Projects</a></li><li><a href="#skills">Skills</a></li><li><a class="nav-cta" href="#contact">Let's talk</a></li></ul></div></nav>
  <main id="top">
    <header class="hero"><div class="container hero-grid"><div><div class="eyebrow">Cloud &amp; backend engineer</div><h1>Building systems that stay <span class="accent">solid.</span></h1><p class="hero-copy">I’m Hassan Tahir—a software engineer focused on cloud infrastructure, dependable APIs, and digital products that feel effortless to use.</p><div class="button-row"><a class="button button-primary" href="#projects">Explore my work <span class="arrow">→</span></a><a class="button button-secondary" href="#contact">Start a conversation</a></div></div><div class="orbit-card" aria-label="Hassan Tahir monogram illustration"><div class="portrait-shape"><div class="portrait-grid"></div><span class="portrait-initials">HT</span></div><div class="cloud-chip">AWS // EC2</div><div class="status-chip"><span class="status-dot"></span> AVAILABLE FOR WORK</div></div></div></header>
    <div class="marquee" aria-hidden="true"><div class="marquee-track"><span>Node.js</span><span>AWS</span><span>MySQL</span><span>Docker</span><span>Express</span><span>Linux</span><span>Node.js</span><span>AWS</span><span>MySQL</span><span>Docker</span><span>Express</span><span>Linux</span></div></div>
    <section class="about" id="about"><div class="container"><div class="section-head reveal"><span class="section-index">01 / About</span><div><h2 class="section-title">Curious by nature. Precise by practice.</h2><p class="section-intro">I care about the quiet details behind reliable software: clear boundaries, useful monitoring, sensible infrastructure, and code the next person can understand.</p></div></div><div class="about-grid"><aside class="principle-card reveal"><span class="mono">Working principle</span><blockquote>“Make it clear. Make it resilient. Then make it fast.”</blockquote></aside><div class="about-copy reveal"><p>I’m a computer science graduate and cloud enthusiast based in Pakistan. My work sits where backend development meets infrastructure—turning product ideas into secure services that are straightforward to deploy and operate.</p><p>Whether I’m shaping a REST API, tuning a SQL query, or provisioning an EC2 workload, I look for the simplest architecture that will still serve the next stage of growth.</p><div class="stats" aria-label="Career highlights"><div class="stat"><strong>3+</strong><span>years building</span></div><div class="stat"><strong>12+</strong><span>projects shipped</span></div><div class="stat"><strong>99.9%</strong><span>uptime mindset</span></div></div></div></div></div></section>
    <section class="experience" id="experience"><div class="container"><div class="section-head reveal"><span class="section-index">02 / Experience</span><div><h2 class="section-title">From first commit to production.</h2><p class="section-intro">A journey shaped by backend systems, cloud operations, and plenty of learning in the open.</p></div></div><div class="timeline"><article class="role reveal"><div class="role-date">2025 — Present</div><div><h3>Cloud Engineer</h3><div class="role-company">Nexa Systems · Remote</div></div><p>Designing AWS-hosted services, automating repeatable deployments, and improving observability across production workloads running on EC2 and container infrastructure.</p></article><article class="role reveal"><div class="role-date">2024 — 2025</div><div><h3>Backend Developer</h3><div class="role-company">ByteCraft Labs · Lahore</div></div><p>Built Node.js APIs and MySQL data layers for client products, reducing response times through query optimization, caching, and pragmatic service design.</p></article><article class="role reveal"><div class="role-date">2023 — 2024</div><div><h3>Software Engineering Intern</h3><div class="role-company">Orbit Digital · Islamabad</div></div><p>Shipped internal tools, wrote integration tests, and learned how clean delivery pipelines turn good code into dependable software.</p></article></div></div></section>
    <section class="projects" id="projects"><div class="container"><div class="section-head reveal"><span class="section-index">03 / Selected work</span><div><h2 class="section-title">Proof is in the projects.</h2><p class="section-intro">These project records are queried live from MySQL on the same AWS EC2 instance—because a portfolio should demonstrate the stack, not just describe it.</p></div></div><div class="db-status reveal"><span class="status-dot"></span> MYSQL CONNECTED · <%= projects.length %> RECORD<%= projects.length === 1 ? '' : 'S' %> LOADED</div><div class="projects-grid"><% projects.forEach(function(project, index) { %><article class="project-card reveal" data-number="<%= String(index + 1).padStart(2, '0') %>"><div class="project-meta"><span class="project-number">PROJECT / <%= String(index + 1).padStart(2, '0') %></span><span class="project-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 17l6-6 4 4 6-7"/><path d="M15 8h5v5"/></svg></span></div><h3><%= project.title %></h3><p class="project-description"><%= project.description %></p><div class="project-footer"><div class="project-stack"><%= project.tech_stack %></div><% if (project.live_url) { %><a class="project-link" href="<%= project.live_url %>" target="_blank" rel="noopener noreferrer" aria-label="View <%= project.title %>">View project <span class="arrow">→</span></a><% } %></div></article><% }); %><% if (projects.length === 0) { %><div class="empty-state">No projects yet. Run <span class="mono">node db/init.js</span> to seed the database.</div><% } %></div></div></section>
    <section class="skills" id="skills"><div class="container"><div class="section-head reveal"><span class="section-index">04 / Toolkit</span><div><h2 class="section-title">Tools I trust to get the job done.</h2></div></div><div class="skills-layout reveal"><p class="skills-note">I choose technology around the problem, not the trend. These are the tools I reach for most often when building, shipping, and maintaining software.</p><div class="skill-list" aria-label="Technical skills"><span class="skill">JavaScript</span><span class="skill">Node.js</span><span class="skill">Express</span><span class="skill">Python</span><span class="skill">MySQL</span><span class="skill">PostgreSQL</span><span class="skill">REST APIs</span><span class="skill">AWS EC2</span><span class="skill">AWS S3</span><span class="skill">Docker</span><span class="skill">Linux</span><span class="skill">Git &amp; CI/CD</span><span class="skill">CloudWatch</span><span class="skill">Terraform</span></div></div></div></section>
    <section class="contact" id="contact"><div class="container contact-inner reveal"><div class="eyebrow">Have a project in mind?</div><h2>Let’s build something dependable.</h2><p>I’m open to cloud engineering roles, backend projects, and thoughtful collaborations. Tell me what you’re working on.</p><div class="button-row"><a class="button button-primary" href="mailto:hassan.tahir@example.com">Email Hassan <span class="arrow">→</span></a><a class="button button-secondary" href="https://www.linkedin.com" target="_blank" rel="noopener noreferrer">LinkedIn</a></div></div></section>
  </main>
  <footer><div class="container footer-inner"><span>© <span id="year"></span> Hassan Tahir · Built with Node.js, Express, EJS &amp; MySQL</span><div class="footer-links"><a href="https://github.com" target="_blank" rel="noopener noreferrer">GitHub</a><a href="#top">Back to top ↑</a></div></div></footer>
  <script>
    const menuButton=document.querySelector('.menu-button'); const navLinks=document.querySelector('.nav-links');
    menuButton.addEventListener('click',()=>{const isOpen=navLinks.classList.toggle('open');menuButton.setAttribute('aria-expanded',String(isOpen));});
    navLinks.querySelectorAll('a').forEach(link=>link.addEventListener('click',()=>{navLinks.classList.remove('open');menuButton.setAttribute('aria-expanded','false');}));
    document.getElementById('year').textContent=new Date().getFullYear();
    const revealObserver=new IntersectionObserver(entries=>{entries.forEach(entry=>{if(entry.isIntersecting){entry.target.classList.add('visible');revealObserver.unobserve(entry.target);}});},{threshold:.12});
    document.querySelectorAll('.reveal').forEach(element=>revealObserver.observe(element));
  </script>
</body>
</html>
